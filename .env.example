APP_NAME=JARVIS
APP_HOST=127.0.0.1
APP_PORT=8765
DATABASE_URL=sqlite:///./jarvis.db
LOG_LEVEL=INFO

# Gemini. Get a free-tier key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
USE_GEMINI_BY_DEFAULT=false
USER_NAME=Abanindra

# Voice and wake word
WAKE_WORD=Cipher
WAKE_WORD_ALIASES=cipher,cypher,sipher,sifer,safer,sypher,cifer
WAKE_LISTEN_SECONDS=5
WAKE_DEBUG=true
WAKE_WORD_ENGINE=text
VOICE_AUTH_ENABLED=false
VOICE_PROFILE_PATH=./data/voiceprint.npy
VOICE_AUTH_THRESHOLD=0.55
VOICE_REJECT_MESSAGE=Voice not authorized. I can only respond to Abanindra.
TTS_RATE=165
TTS_VOLUME=0.95

# Internet providers. Leave blank to use free/no-key fallbacks where supported.
OPENWEATHER_API_KEY=
NEWS_RSS_URL=https://www.thehindu.com/news/national/feeder/default.rss
JOBS_RSS_URL=https://remoteok.com/remote-python-jobs.rss
